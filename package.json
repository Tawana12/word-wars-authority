{
  "name": "word-wars-authority",
  "version": "1.0.0",
  "private": true,
  "description": "In-memory authoritative multiplayer server for Word Wars, bridged through Devvit HTTP and Realtime.",
  "main": "dist/main.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx src/smoke.ts"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.43",
    "@colyseus/ws-transport": "^0.17.13",
    "dotenv": "^16.6.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
